vroot
    vlayout padding:10
        label id:titleLabel
        hlayout id:idContent visible:false
            label id:idContentLabel
            htextbox fw:120 disable:true id:idContentKind
        hlist id:listContent
        htextbox id:detailTextField
    hline
    hlayout padding:10
        hbtnbox text:OK id:okBtn
        hspacer
        hbtnbox text:Cancel id:cancelBtn