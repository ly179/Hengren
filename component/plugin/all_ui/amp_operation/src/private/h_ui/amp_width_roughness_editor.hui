hroot
    hscrollarea hn:need hb:on padl:3 padr:3 padt:3 padr:0 id:detailContent
        vlayout align:top
            htitlebox text:"Target Object Setting" padb:5
                glayout align:left hspacing:80
                    label text:Object grid:0,0
                    hitembox grid:0,1 galign:left id:objectCBox
                        item text:Line val:0
                        item text:"Space" val:1
                        item text: "Pitch(Left)" val:2
                        item text:"Pitch(Right)" val:3
                        item text:Top val:4
                        item text:"Slope(Left)" val:5
                        item text:"Slope(Right)" val:6
                        item text:"Dense Line" val:7
                        item text:"Dense Space" val:8
                    label text:Data grid:1,0
                    ditembox grid:1,1 galign:left id:dataCBox
                    hlayout grid:2,0,1,2 padding:5 align:left
                        cbox text:"B.F. Fast Mode" id:bfCheckBox
            hline
            htitlebox text:"ACD Setting" padb:5
                hlayout spacing:5 padding:5,5,0,10 align:left
                    hitembox id:acdCBox
                        item text:ACD val:0
                        item text:"Min CD" val:1
                        item text:"Max CD" val:2
                        item text:"3Sigma CD" val:3
                        item text:"Mean‘" val:4
                    ditembox id:acdWayCBox
                    label text:Target
                    htextbox fw:50 ph:1 id:acdTargetTextField
                    label text:Limit
                    htextbox fw:50 ph:1 id:acdLimitTextField
            hline
            htitlebox text:"Dense Object Setting" padb:5
                hlayout id:denseObjectSettingContent
            hline
            htitlebox text:"Measurement Area Setting" padb:5
                glayout align:top,left hspacing:3 padding:5,5,0,10
                    label text:"Cursor Type" grid:0,0
                    hitembox grid:0,1 galign:right id:mCursorTypeCBox
                        item text:"Two Box" val:0
                        item text:"One Box" val:1
                    hlayout grid:1,0 align:left padt:5
                        vlayout
                            label text:"Design Value"
                            label text:"(1.0~200000.0)" style:"QLabel {font-size:8pt;}" align:center
                    hlayout grid:1,1 align:top,right
                        htextbox fw:80 ph:"500.0" id:mDesignValueTextField
                    label text:nm grid:1,2
                    hlayout id:searchAreaLabelContent grid:2,0 align:left hk:true
                        vlayout padt:5
                            label text:"Search Area"
                            label text:"(10~150)" style:"QLabel {font-size:8pt;}" align:center
                    hlayout id:searchAreaTextContent grid:2,1 align:top,right hk:true
                        htextbox fw:50 ph:80 id:mSearchAreaTextField
                    hlayout id:measurePointLabelContent grid:2,2 align:left hk:true
                        vlayout padt:5
                            label text:"Measurement Point"
                            label text:"(8,16,32~400)" style:"QLabel {font-size:8pt;}" align:left
                    hlayout id:measurePointTextContent grid:2,3 align:top,right hk:true
                        htextbox ph:16 fw:50 id:mMeasurePointTextField
                    hlayout id:inspectAreaLabelContent grid:3,0 align:left hk:true
                        vlayout padt:5
                            label text:"Inspect Area"
                            label text:"(1~400)" style:"QLabel {font-size:8pt;}" align:center
                    hlayout id:inspectAreaTextContent grid:3,1 align:top,right hk:true
                        htextbox fw:50 ph:200 id:mInspectTextField
                    hlayout id:sumLinesLabelContent grid:3,2 align:left hk:true
                        vlayout padt:5
                            label text:"Sum Lines / Points"
                            label text:"(1~64)" style:"QLabel {font-size:8pt;}" align:left
                    hlayout id:sumLinesTextContent grid:3,3 align:top,right hk:true
                        htextbox fw:50 ph:16 id:mSumLinePointTextField
                    hlayout grid:4,0,1,3 align:left spacing:15
                        label text:"Measurement Position"
                        ditembox id:measurePositionCBox
            hline
            htitlebox text:"Detection Method Setting" padb:5
                vlayout align:top,left  padl:10
                    glayout hspacing:10
                        label text:Method grid:0,0
                        hitembox grid:0,1 galign:right id:dmMethodCBox
                            item text:Linear val:0
                            item text:Threshold val:1
                            item text:Differential val:2
                        vlayout grid:0,2 padt:5
                            label text:Smoothing
                            label text:"(1~29(odd))" style:"QLabel {font-size:8pt;}"
                        htextbox fw:60 ph:7 grid:0,3 galign:top id:dmSmoothingTextField
                        label text:"Pre Process" grid:1,0
                        hitembox grid:1,1 galign:right id:dmPreProcessCBox
                            item text:Inverse val:0
                            item text:Shading val:1
                            item text:None val:2
                        vlayout grid:1,2 padt:5
                            label text:Differential
                            label text:"(3~19(odd))" style:"QLabel {font-size:8pt;}"
                        htextbox fw:60 ph:5 grid:1,3 galign:top id:dmDiffTextField
                    ampds id:commonSettingController
            hline
