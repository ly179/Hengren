vroot
    vlayout padding:10,10,0,10
        label text:"Template Name"
    hlayout padding:5,25
        htextbox id:nameTextField
    hlayout padding:0,10,5,28
        cbox id:overloadCheckBox text:"Save using the same name as Measurement Template" disable:true
    hline
    hlayout padding:10
        hbtnbox text:OK id:okBtn
        hspacer
        hbtnbox text:Cancel id:cancel