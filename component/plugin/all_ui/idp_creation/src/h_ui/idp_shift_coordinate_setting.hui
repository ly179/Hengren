vroot
    glayout padding:20 hspacing:10 vspacing:5
        label text:Shift grid:0,0
        label text:X grid:0,1
        htextbox fw:100 grid:0,2 id:xTextField
        label text:"μm" grid:0,3
        label text:Y grid:1,1
        htextbox fw:100 grid:1,2 id:yTextField
        label text:"μm" grid:1,3
    hline
    hlayout padding:10
        hbtnbox text:OK id:okBtn
        hspacer
        hbtnbox text:Cancel id:cancelBtn